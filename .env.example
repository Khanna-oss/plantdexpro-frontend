# PlantDexPro Frontend Environment Variables

# Gemini API Key for plant identification (client-side)
# Get your key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Backend API URL (optional - for future backend integration)
# Local development: http://localhost:5000
# Production: https://your-backend.onrender.com
VITE_BACKEND_URL=http://localhost:5000

# Trefle API Key (optional - for botanical enrichment)
# Free tier: 120 requests/day
# Get your key from: https://trefle.io/
VITE_TREFLE_API_KEY=your_trefle_api_key_here

# Note: Wikipedia API is free and requires no API key
# Note: YouTube videos are fetched via Gemini's Google Search tool (no separate key needed)
